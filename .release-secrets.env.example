# Copy to .release-secrets.env (gitignored) and fill in.  Then run:
#   scripts/setup-release-secrets.sh
# GitHub secrets are write-only, so this local file is how you (re)set them.
# "Same as visio" = identical value to the visio-mobile secret, because both
# apps share Apple team KUT463DS29, the match repo, and the Firebase/Play project.

# ── Android signing (twake-SPECIFIC — generate your own keystore, see runbook) ──
ANDROID_KEYSTORE_FILE=/absolute/path/to/twake-drive-release.keystore
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=twakedrive
ANDROID_KEY_PASSWORD=

# ── Android distribution (Firebase App Distribution + Play) ──
# FIREBASE_APP_ID is twake-SPECIFIC (register com.linagora.twakedrive in Firebase).
FIREBASE_APP_ID=
# Service account JSON with Firebase App Distribution (+ Play) access — same as visio if same project.
GCP_SERVICE_ACCOUNT_FILE=/absolute/path/to/gcp-service-account.json

# ── iOS signing / distribution (all SAME AS VISIO — same Apple account) ──
APPLE_TEAM_ID=KUT463DS29
APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_ISSUER_ID=
# Provide EITHER the .p8 file (auto-base64'd) OR the already-base64 content:
APP_STORE_CONNECT_API_KEY_FILE=/absolute/path/to/AuthKey_XXXX.p8
#APP_STORE_CONNECT_API_KEY_CONTENT=

# fastlane match (encrypted certs/profiles repo — same repo as visio)
MATCH_GIT_URL=
MATCH_PASSWORD=
# SSH private key granting CI read access to the match repo (file path):
MATCH_DEPLOY_KEY_FILE=/absolute/path/to/match_deploy_key
#MATCH_DEPLOY_KEY=
